# .env.example - Copy to .env and modify configuration

# ================================
# Server Configuration
# ================================
SERVER_PORT=8080
SERVER_MODE=debug
ENABLE_SWAGGER=true

# ================================
# Database Configuration
# ================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=servermind
DB_PASSWORD=servermind_dev
DB_NAME=servermind
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m
DB_SSLMODE=disable

# ================================
# Redis Configuration
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=servermind_dev
REDIS_DB=0

# ================================
# JWT Configuration
# ================================
JWT_SECRET=change_this_secret_in_production
JWT_TOKEN_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h

# ================================
# SSH Configuration
# ================================
SSH_CONNECT_TIMEOUT=30s
SSH_COMMAND_TIMEOUT=300s
SSH_MAX_CONNECTIONS=100
SSH_KEEP_ALIVE=60s
SSH_SESSION_RECORDING=true

# ================================
# Milvus Configuration (Vector DB for RAG)
# ================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USERNAME=root
MILVUS_PASSWORD=Milvus
MILVUS_DB_NAME=default

# ================================
# Neo4j Configuration (Graph DB)
# ================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=servermind_dev

# ================================
# ClickHouse Configuration (Time-series DB)
# ================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=servermind
CLICKHOUSE_PASSWORD=servermind_dev
CLICKHOUSE_DB=servermind

# ================================
# Temporal Configuration (Workflow Engine)
# ================================
TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=sera-deployments

# ================================
# NATS JetStream Configuration (Message Bus)
# ================================
NATS_URL=nats://localhost:4222
NATS_CLUSTER_ID=sera-cluster

# ================================
# Vault Configuration (Secret Management)
# ================================
VAULT_ADDRESS=http://localhost:8200
VAULT_TOKEN=servermind_dev_token
VAULT_SSH_ENGINE_PATH=ssh

# ================================
# MinIO Configuration (Object Storage)
# ================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=sera-recordings
MINIO_USE_SSL=false

# ================================
# LLM Configuration
# ================================
LLM_PROVIDER=anthropic
LLM_API_KEY=your-api-key-here
LLM_MODEL=claude-sonnet-4-6-20250929
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# ================================
# GitHub Configuration
# ================================
GITHUB_TOKEN=
GITHUB_RATE_LIMIT_WAIT=true

# ================================
# Security Sandbox
# ================================
SANDBOX_ENABLED=true
SANDBOX_LOG_BLOCKED=true

# ================================
# Logging
# ================================
LOG_LEVEL=info
LOG_FORMAT=json
